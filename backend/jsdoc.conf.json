{
  "source": {
    "include": ["./src/"],
    "includePattern": ".+\\.js(doc|x)?$",
    "exclude": ["node_modules/", "tests/", "uploads/", "logs/"]
  },
  "opts": {
    "destination": "./docs/",
    "recurse": true
  },
  "plugins": [
    "plugins/markdown",
    "plugins/summarize"
  ],
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false,
    "default": {
      "outputSourceFiles": true,
      "includeDate": true
    }
  },
  "markdown": {
    "parser": "gfm",
    "hardwrap": true
  }
}
